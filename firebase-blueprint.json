{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A cake or bakery item for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Birthday", "Anniversary", "Wedding", "Cupcakes", "Pastries"] },
        "imageUrl": { "type": "string", "format": "uri" },
        "characteristics": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category", "imageUrl"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for cakes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "cakeName": { "type": "string" },
              "cakeDesign": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "deliveryDetails": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "deliveryDate": { "type": "string", "format": "date-time" }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "picked", "ready", "delivered"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "paymentMethod": { "type": "string", "enum": ["esewa", "khalti"] },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "message": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "deliveryDetails", "totalAmount", "status", "paymentStatus"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Catalog of cakes and items"
    },
    "/orders": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
